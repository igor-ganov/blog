---
import type { GetStaticPaths } from 'astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { loadArticles } from '@/lib/articles/load-articles';
import { type Locale, defaultLocale, isLocale, locales } from '@/lib/i18n/locales';
import { withLocale } from '@/lib/i18n/locale-url';
import { t } from '@/lib/i18n/ui';
import { categories } from '@/lib/categories/categories';

export const getStaticPaths: GetStaticPaths = () => locales.map((lang) => ({ params: { lang } }));

const param = String(Astro.params.lang ?? '');
const locale: Locale = isLocale(param) ? param : defaultLocale;
const ui = t(locale);
const about = ui.pages.about;
const articles = await loadArticles(locale);
const projects = new Set(articles.flatMap((a) => a.sources.map((s) => s.project)));
const builtHtml = about.built
  .replace('{projects}', String(projects.size))
  .replace('{categories}', String(categories.length))
  .replace('{articles}', String(articles.length));
---

<BaseLayout title={ui.nav.about} description={about.description} locale={locale}>
  <article class="prose page">
    <h1>{about.title}</h1>
    <p class="lede">{about.lede}</p>

    <h2>{about.whyHeading}</h2>
    <p>{about.whyIntro}</p>
    <ol>
      <li set:html={about.why1}></li>
      <li set:html={about.why2}></li>
      <li>
        <Fragment set:html={about.why3Pre} />
        <a href={withLocale(locale, '/skills')}>{ui.nav.skills}</a>
        <Fragment set:html={about.why3Post} />
      </li>
      <li set:html={about.why4}></li>
    </ol>

    <h2>{about.builtHeading}</h2>
    <p set:html={builtHtml}></p>

    <h2>{about.newerHeading}</h2>
    <p>
      <Fragment set:html={about.newerPre} />
      <a href={withLocale(locale, '/kb/functional-architecture/errors-as-values-with-effect')}
        >{about.newerLink}</a
      ><Fragment set:html={about.newerPost} />
    </p>

    <h2>{about.sevHeading}</h2>
    <p>{about.sevIntro}</p>
    <ul>
      <li><strong>{ui.severity['non-negotiable']}</strong> — {about.sevNonNeg}</li>
      <li><strong>{ui.severity.strong}</strong> — {about.sevStrong}</li>
      <li><strong>{ui.severity.preferred}</strong> — {about.sevPreferred}</li>
      <li><strong>{ui.severity.context}</strong> — {about.sevContext}</li>
    </ul>

    <h2>{about.readHeading}</h2>
    <p>
      <Fragment set:html={about.readPre} />
      <a href={withLocale(locale, '/')}>{about.readLink}</a>
      <Fragment set:html={about.readPost} />
    </p>

    <h2>{about.builtWithHeading}</h2>
    <p set:html={about.builtWith}></p>
  </article>

  <style>
    .page {
      padding: var(--space-8) 0;
    }
    .lede {
      font-size: var(--step-1);
      color: var(--text-muted);
    }
    ol,
    ul {
      padding-inline-start: 1.2em;
    }
    li {
      margin: var(--space-2) 0;
    }
  </style>
</BaseLayout>
