---
import type { GetStaticPaths } from 'astro';
import { getCollection } from 'astro:content';
import EssayCard from '@/components/EssayCard.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { sortEssays } from '@/lib/essays/sort-essays';
import { type Locale, defaultLocale, isLocale, locales, splitLocaleId } from '@/lib/i18n/locales';
import { t } from '@/lib/i18n/ui';

export const getStaticPaths: GetStaticPaths = () => locales.map((lang) => ({ params: { lang } }));

const param = String(Astro.params.lang ?? '');
const locale: Locale = isLocale(param) ? param : defaultLocale;
const ui = t(locale);
const posts = sortEssays(
  (await getCollection('blog', (entry) => entry.data.draft === false)).filter(
    (entry) => splitLocaleId(entry.id).locale === locale,
  ),
);
---

<BaseLayout title={ui.nav.blog} description={ui.pages.essaysIndex.description} locale={locale}>
  <header class="page-head">
    <h1>{ui.nav.blog}</h1>
    <p class="lede">{ui.pages.essaysIndex.lede}</p>
  </header>

  <ul class="posts">
    {posts.map((post) => <EssayCard post={post} headingLevel={2} />)}
  </ul>

  <style>
    .page-head {
      padding: var(--space-8) 0 var(--space-5);
      max-width: 60ch;
    }
    .lede {
      font-size: var(--step-1);
      color: var(--text-muted);
    }
    .posts {
      list-style: none;
      margin: 0;
      padding: 0;
      display: flex;
      flex-direction: column;
      gap: var(--space-4);
    }
  </style>
</BaseLayout>
