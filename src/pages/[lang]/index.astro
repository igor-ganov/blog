---
import type { GetStaticPaths } from 'astro';
import { getCollection } from 'astro:content';
import ArticleCard from '@/components/ArticleCard.astro';
import CategoryCard from '@/components/CategoryCard.astro';
import EssayCard from '@/components/EssayCard.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { groupByCategory } from '@/lib/articles/group-by-category';
import { loadArticles } from '@/lib/articles/load-articles';
import { sortEssays } from '@/lib/essays/sort-essays';
import { type Locale, defaultLocale, isLocale, locales, splitLocaleId } from '@/lib/i18n/locales';
import { withLocale } from '@/lib/i18n/locale-url';
import { loadHome } from '@/lib/i18n/load-page';
import { categories } from '@/lib/categories/categories';

export const getStaticPaths: GetStaticPaths = () => locales.map((lang) => ({ params: { lang } }));

const param = String(Astro.params.lang ?? '');
const locale: Locale = isLocale(param) ? param : defaultLocale;
const home = await loadHome(locale);
const articles = await loadArticles(locale);
const grouped = groupByCategory(articles);
const nonNegotiables = articles.filter((article) => article.severity === 'non-negotiable');
const latestPosts = sortEssays(
  (await getCollection('blog', (entry) => entry.data.draft === false)).filter(
    (entry) => splitLocaleId(entry.id).locale === locale,
  ),
).slice(0, 5);
---

<BaseLayout title={home.title} description={home.description} locale={locale}>
  <section class="hero">
    <p class="kicker">{home.kicker}</p>
    <h1>{home.h1}</h1>
    <p class="lede" set:html={home.lede}></p>
    <dl class="stats">
      <div><dt>{home.statPractices}</dt><dd>{articles.length}</dd></div>
      <div><dt>{home.statCategories}</dt><dd>{categories.length}</dd></div>
      <div><dt>{home.statNonNegotiable}</dt><dd>{nonNegotiables.length}</dd></div>
    </dl>
  </section>

  {
    latestPosts.length > 0 && (
      <section class="block">
        <div class="block-head">
          <h2>{home.blogHeading}</h2>
          <a class="more" href={withLocale(locale, '/blog')}>
            {home.blogAll} <span aria-hidden="true">→</span>
          </a>
        </div>
        <p class="block-lede">{home.blogLede}</p>
        <ul class="essays">
          {latestPosts.map((post) => (
            <EssayCard post={post} headingLevel={3} />
          ))}
        </ul>
      </section>
    )
  }

  {
    nonNegotiables.length > 0 && (
      <section class="block">
        <h2>{home.nonNegHeading}</h2>
        <p class="block-lede">{home.nonNegLede}</p>
        <div class="grid">
          {nonNegotiables.slice(0, 6).map((article) => (
            <ArticleCard article={article} showCategory />
          ))}
        </div>
      </section>
    )
  }

  <section class="block">
    <h2>{home.browseHeading}</h2>
    <p class="block-lede">{home.browseLede}</p>
    <div class="grid cats">
      {
        categories.map((category) => (
          <CategoryCard
            category={category}
            count={(grouped.get(category.slug) ?? []).length}
            locale={locale}
          />
        ))
      }
    </div>
  </section>

  <style>
    .hero {
      padding: var(--space-12) 0 var(--space-8);
      max-width: 60ch;
    }
    .kicker {
      text-transform: uppercase;
      letter-spacing: 0.1em;
      font-size: var(--step--1);
      color: var(--accent);
      margin: 0 0 var(--space-3);
    }
    h1 {
      font-size: var(--step-4);
    }
    .lede {
      font-size: var(--step-1);
      color: var(--text-muted);
    }
    .stats {
      display: flex;
      gap: var(--space-8);
      margin: var(--space-6) 0 0;
    }
    .stats dt {
      font-size: var(--step--1);
      color: var(--text-faint);
      text-transform: uppercase;
      letter-spacing: 0.06em;
    }
    .stats dd {
      margin: 0;
      font-family: var(--font-serif);
      font-size: var(--step-3);
      color: var(--text);
    }
    .block {
      padding: var(--space-6) 0;
    }
    .block-head {
      display: flex;
      align-items: baseline;
      justify-content: space-between;
      gap: var(--space-4);
    }
    .block-head h2 {
      margin: var(--space-8) 0 var(--space-3);
    }
    .more {
      flex: none;
      font-size: var(--step--1);
      color: var(--link);
      text-decoration: none;
      white-space: nowrap;
    }
    .more:hover {
      color: var(--link-hover);
    }
    .block-lede {
      color: var(--text-muted);
      margin-top: 0;
    }
    .essays {
      list-style: none;
      margin: var(--space-5) 0 0;
      padding: 0;
      display: flex;
      flex-direction: column;
      gap: var(--space-4);
    }
    .grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(min(100%, 20rem), 1fr));
      gap: var(--space-4);
      margin-top: var(--space-5);
    }
  </style>
</BaseLayout>
