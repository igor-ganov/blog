---
import type { GetStaticPaths } from 'astro';
import { type CollectionEntry, getCollection, render } from 'astro:content';
import ArticleAside from '@/components/ArticleAside.astro';
import SeverityBadge from '@/components/SeverityBadge.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import type { Article } from '@/lib/articles/article-types';
import { articleHref } from '@/lib/articles/article-href';
import { groupByCategory } from '@/lib/articles/group-by-category';
import { loadArticles } from '@/lib/articles/load-articles';
import { toArticle } from '@/lib/articles/to-article';
import { splitLocaleId } from '@/lib/i18n/locales';
import { withLocale } from '@/lib/i18n/locale-url';
import { t } from '@/lib/i18n/ui';
import { categoryBySlug } from '@/lib/categories/categories';
import { localizeCategory } from '@/lib/categories/localize-category';

export const getStaticPaths: GetStaticPaths = async () => {
  const entries = await getCollection('kb', (entry) => entry.data.draft === false);
  return entries.map((entry) => {
    const { locale, rest } = splitLocaleId(entry.id);
    return { params: { lang: locale, id: rest }, props: { entry } };
  });
};

interface Props {
  readonly entry: CollectionEntry<'kb'>;
}

const { entry } = Astro.props;
const article = toArticle(entry);
const { locale } = article;
const ui = t(locale);
const category = categoryBySlug(article.category);
const categoryTitle = category ? localizeCategory(category, locale).title : '';
const { Content, headings } = await render(entry);

const all = await loadArticles(locale);
const byId = new Map(all.map((item) => [item.id, item]));
const relatedLinks = article.related
  .map((id) => byId.get(id))
  .filter((item): item is Article => Boolean(item))
  .map((item) => ({ href: articleHref(item), title: item.title }));

const siblings = groupByCategory(all).get(article.category) ?? [];
const index = siblings.findIndex((item) => item.id === article.id);
const prev = siblings[index - 1];
const next = siblings[index + 1];
const toc = headings.filter((heading) => heading.depth === 2);
---

<BaseLayout title={article.title} description={article.summary} locale={locale}>
  <reading-progress></reading-progress>
  <script>
    import '@/components/islands/reading-progress';
    import '@/components/islands/toc-drawer';
  </script>

  <nav class="crumbs" aria-label={ui.breadcrumb.label}>
    <a href={withLocale(locale, '/principles')}>{ui.breadcrumb.principles}</a> <span aria-hidden="true">/</span>
    {category && <a href={withLocale(locale, `/c/${category.slug}`)}>{categoryTitle}</a>}
  </nav>

  <div class="layout">
    <article class="article">
      <header class="head">
        <div class="badges">
          <SeverityBadge severity={article.severity} locale={locale} />
        </div>
        <h1>{article.title}</h1>
        <p class="summary">{article.summary}</p>
        <p class="principle"><strong>{ui.article.principleLabel}</strong> {article.principle}</p>
      </header>

      <div class="prose">
        <Content />
      </div>

      <nav class="pager" aria-label={ui.pager.withinCategory}>
        {
          prev && (
            <a class="prev" href={articleHref(prev)}>
              <span class="dir">{ui.pager.previous}</span>
              <span class="t">{prev.title}</span>
            </a>
          )
        }
        {
          next && (
            <a class="next" href={articleHref(next)}>
              <span class="dir">{ui.pager.next}</span>
              <span class="t">{next.title}</span>
            </a>
          )
        }
      </nav>
    </article>

    <div class="sidebar">
      {
        toc.length > 1 && (
          <toc-drawer
            heading={ui.toc.onThisPage}
            closeLabel={ui.toc.close}
            headings={JSON.stringify(toc.map((heading) => ({ id: heading.slug, text: heading.text })))}
          >
            {/* Server-rendered desktop TOC, matching the island's inline panel so the
                sidebar does not reflow on hydration. Once the element upgrades, its
                shadow root (which has no slot) hides this light-DOM skeleton. */}
            <div class="toc-ssr" aria-hidden="true">
              <h2 class="toc-ssr-label">{ui.toc.onThisPage}</h2>
              <ul class="toc-ssr-list">
                {toc.map((heading) => (
                  <li>
                    <a href={`#${heading.slug}`}>{heading.text}</a>
                  </li>
                ))}
              </ul>
            </div>
          </toc-drawer>
        )
      }
      <ArticleAside
        sources={article.sources}
        related={relatedLinks}
        tags={article.tags}
        locale={locale}
      />
    </div>
  </div>

  <style>
    .crumbs {
      padding-top: var(--space-6);
      color: var(--text-faint);
      font-size: var(--step--1);
    }
    .crumbs a {
      color: var(--text-muted);
    }
    .layout {
      display: grid;
      grid-template-columns: minmax(0, 1fr);
      gap: var(--space-8);
      padding: var(--space-4) 0 var(--space-8);
    }
    @media (min-width: 60rem) {
      .layout {
        grid-template-columns: minmax(0, 1fr) 16rem;
        align-items: start;
      }
      .sidebar {
        position: sticky;
        top: 5rem;
      }
    }
    .head {
      max-width: var(--measure);
    }
    .summary {
      font-size: var(--step-1);
      color: var(--text-muted);
    }
    .principle {
      border-left: 3px solid var(--accent);
      background: var(--bg-sunken);
      padding: var(--space-3) var(--space-4);
      border-radius: 0 var(--radius-sm) var(--radius-sm) 0;
    }
    .sidebar {
      display: flex;
      flex-direction: column;
      gap: var(--space-6);
    }

    /* Skeleton matching toc-drawer's inline desktop panel (same metrics), shown only
       until the island upgrades. Hidden under 60rem where the drawer is a button. */
    .toc-ssr-label {
      font-family: var(--font-sans);
      font-size: 0.74rem;
      /* Match the shadow panel's h2, which is isolated from the global h2 rule and
         so keeps the inherited body line-height/UA weight. */
      font-weight: 700;
      line-height: 1.65;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: var(--text-faint);
      margin: 0 0 var(--space-3);
    }
    .toc-ssr-list {
      list-style: none;
      margin: 0;
      padding: 0;
      display: flex;
      flex-direction: column;
      gap: var(--space-2);
      font-size: var(--step--1);
    }
    .toc-ssr-list a {
      display: block;
      color: var(--text-muted);
      text-decoration: none;
      padding: 0.15em 0;
    }
    @media (max-width: 60rem) {
      .toc-ssr {
        display: none;
      }
    }
    .pager {
      display: flex;
      justify-content: space-between;
      gap: var(--space-4);
      margin-top: var(--space-8);
      border-top: 1px solid var(--border);
      padding-top: var(--space-5);
    }
    .pager a {
      display: flex;
      flex-direction: column;
      text-decoration: none;
      max-width: 48%;
    }
    .pager .next {
      text-align: right;
      margin-inline-start: auto;
    }
    .pager .dir {
      font-size: var(--step--1);
      color: var(--text-faint);
    }
    .pager .t {
      color: var(--link);
    }
  </style>
</BaseLayout>
