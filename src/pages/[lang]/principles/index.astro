---
import type { GetStaticPaths } from 'astro';
import ArticleCard from '@/components/ArticleCard.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { groupByCategory } from '@/lib/articles/group-by-category';
import { loadArticles } from '@/lib/articles/load-articles';
import { type Locale, defaultLocale, isLocale, locales } from '@/lib/i18n/locales';
import { t } from '@/lib/i18n/ui';
import { topTags } from '@/lib/tags/top-tags';
import { categories } from '@/lib/categories/categories';

export const getStaticPaths: GetStaticPaths = () => locales.map((lang) => ({ params: { lang } }));

const param = String(Astro.params.lang ?? '');
const locale: Locale = isLocale(param) ? param : defaultLocale;
const ui = t(locale);
const articles = await loadArticles(locale);
const grouped = groupByCategory(articles);
const ordered = categories.flatMap((category) => grouped.get(category.slug) ?? []);
const chipTags = topTags(articles, 14)
  .map((entry) => entry.tag)
  .join(',');
---

<BaseLayout title={ui.nav.principles} description={ui.pages.kbIndex.description} locale={locale}>
  <header class="page-head">
    <h1>{ui.nav.principles}</h1>
    <p class="lede">
      {
        ui.pages.kbIndex.lede
          .replace('{practices}', String(articles.length))
          .replace('{categories}', String(categories.length))
      }
    </p>
  </header>

  <kb-filter
    tags={chipTags}
    placeholder={ui.filter.placeholder}
    label={ui.filter.label}
    emptyText={ui.filter.empty}
    byTagLabel={ui.filter.byTag}
  >
    <div class="grid">
      {ordered.map((article) => <ArticleCard article={article} showCategory />)}
    </div>
  </kb-filter>

  <script>
    import '@/components/islands/kb-filter';
  </script>

  <style>
    .page-head {
      padding: var(--space-8) 0 var(--space-5);
    }
    .lede {
      color: var(--text-muted);
      max-width: 60ch;
    }
    .grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(min(100%, 20rem), 1fr));
      gap: var(--space-4);
    }
  </style>
</BaseLayout>
