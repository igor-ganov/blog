---
import { getCollection } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { formatDate } from '@/lib/format/format-date';
import { withBase } from '@/lib/url/with-base';

const posts = (await getCollection('blog', (entry) => entry.data.draft === false)).sort(
  (a, b) => a.data.order - b.data.order || b.data.date.localeCompare(a.data.date),
);
const description =
  'Essays that aggregate and explain the principles — why this site exists, and how the rules fit together.';
---

<BaseLayout title="Blog" description={description}>
  <header class="page-head">
    <h1>Blog</h1>
    <p class="lede">
      The Principles section is the reference; these essays are the throughline — why this
      knowledge base exists, and how the individual rules add up to a way of building.
    </p>
  </header>

  <ul class="posts">
    {
      posts.map((post) => (
        <li class="post">
          <a class="hit" href={withBase(`/essays/${post.id}`)} aria-label={post.data.title} />
          <time class="date" datetime={post.data.date}>
            {formatDate(post.data.date)}
          </time>
          <h2 class="title">{post.data.title}</h2>
          <p class="summary">{post.data.description}</p>
        </li>
      ))
    }
  </ul>

  <style>
    .page-head {
      padding: var(--space-8) 0 var(--space-5);
      max-width: 60ch;
    }
    .lede {
      font-size: var(--step-1);
      color: var(--text-muted);
    }
    .posts {
      list-style: none;
      margin: 0;
      padding: 0;
      display: flex;
      flex-direction: column;
      gap: var(--space-4);
    }
    .post {
      position: relative;
      background: var(--bg-raised);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: var(--space-5);
      transition: border-color 0.15s ease, transform 0.15s ease, box-shadow 0.15s ease;
    }
    .post:hover {
      border-color: var(--border-strong);
      transform: translateY(-2px);
      box-shadow: var(--shadow);
    }
    .post:focus-within {
      outline: 3px solid var(--accent);
      outline-offset: 2px;
    }
    .hit {
      position: absolute;
      inset: 0;
      border-radius: inherit;
    }
    .hit:focus-visible {
      outline: none;
    }
    .date {
      font-size: var(--step--1);
      color: var(--text-faint);
      font-variant-numeric: tabular-nums;
    }
    .title {
      margin: var(--space-2) 0 var(--space-1);
      font-size: var(--step-2);
    }
    .summary {
      margin: 0;
      color: var(--text-muted);
    }
  </style>
</BaseLayout>
