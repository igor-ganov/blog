---
import type { GetStaticPaths } from 'astro';
import { type CollectionEntry, getCollection, render } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { formatDate } from '@/lib/format/format-date';
import { withBase } from '@/lib/url/with-base';

export const getStaticPaths: GetStaticPaths = async () => {
  const entries = await getCollection('blog', (entry) => entry.data.draft === false);
  return entries.map((entry) => ({ params: { id: entry.id }, props: { entry } }));
};

interface Props {
  readonly entry: CollectionEntry<'blog'>;
}

const { entry } = Astro.props;
const { Content } = await render(entry);
---

<BaseLayout title={entry.data.title} description={entry.data.description}>
  <nav class="crumbs" aria-label="Breadcrumb">
    <a href={withBase('/essays')}>Blog</a>
  </nav>

  <article class="post">
    <header class="head">
      <time class="date" datetime={entry.data.date}>{formatDate(entry.data.date)}</time>
      <h1>{entry.data.title}</h1>
      <p class="lede">{entry.data.description}</p>
    </header>

    <div class="prose">
      <Content />
    </div>
  </article>

  <style>
    .crumbs {
      padding-top: var(--space-6);
      color: var(--text-faint);
      font-size: var(--step--1);
    }
    .crumbs a {
      color: var(--text-muted);
    }
    .post {
      padding: var(--space-4) 0 var(--space-8);
    }
    .head {
      max-width: var(--measure);
      margin-bottom: var(--space-6);
    }
    .date {
      font-size: var(--step--1);
      color: var(--text-faint);
      font-variant-numeric: tabular-nums;
    }
    .head h1 {
      margin: var(--space-2) 0 var(--space-3);
    }
    .lede {
      font-size: var(--step-1);
      color: var(--text-muted);
    }
  </style>
</BaseLayout>
