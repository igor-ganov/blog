---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { defaultLocale } from '@/lib/i18n/locales';
import { withLocale } from '@/lib/i18n/locale-url';
import { t } from '@/lib/i18n/ui';

const nf = t(defaultLocale).pages.notFound;
---

<BaseLayout title={nf.title} description={nf.description} locale={defaultLocale}>
  <section class="nf">
    <p class="code">404</p>
    <h1>{nf.heading}</h1>
    <p class="lede">{nf.lede}</p>
    <a class="cta" href={withLocale(defaultLocale, '/kb')}>{nf.cta}</a>
  </section>

  <style>
    .nf {
      padding: var(--space-12) 0;
      text-align: center;
    }
    .code {
      font-family: var(--font-mono);
      color: var(--accent);
      font-size: var(--step-2);
      margin: 0;
    }
    .lede {
      color: var(--text-muted);
      margin-inline: auto;
    }
    .cta {
      display: inline-block;
      margin-top: var(--space-5);
      background: var(--blue-700);
      color: #fff;
      padding: var(--space-3) var(--space-5);
      border-radius: var(--radius);
      text-decoration: none;
    }
  </style>
</BaseLayout>
