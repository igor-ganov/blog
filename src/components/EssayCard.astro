---
import type { CollectionEntry } from 'astro:content';
import { formatDate } from '@/lib/format/format-date';
import { splitLocaleId } from '@/lib/i18n/locales';
import { withLocale } from '@/lib/i18n/locale-url';

interface Props {
  readonly post: CollectionEntry<'blog'>;
  readonly headingLevel?: 2 | 3;
}

const { post, headingLevel = 2 } = Astro.props;
const Heading = `h${headingLevel}` as const;
const { locale, rest } = splitLocaleId(post.id);
const href = withLocale(locale, `/essays/${rest}`);
---

<li class="essay">
  <a class="hit" href={href} aria-label={post.data.title}></a>
  <time class="date" datetime={post.data.date}>{formatDate(post.data.date, locale)}</time>
  <Heading class="title">{post.data.title}</Heading>
  <p class="summary">{post.data.description}</p>
</li>

<style>
  .essay {
    position: relative;
    list-style: none;
    background: var(--bg-raised);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: var(--space-5);
    transition: border-color 0.15s ease, transform 0.15s ease, box-shadow 0.15s ease;
  }
  .essay:hover {
    border-color: var(--border-strong);
    transform: translateY(-2px);
    box-shadow: var(--shadow);
  }
  .essay:focus-within {
    outline: 3px solid var(--accent);
    outline-offset: 2px;
  }
  .hit {
    position: absolute;
    inset: 0;
    border-radius: inherit;
  }
  .hit:focus-visible {
    outline: none;
  }
  .date {
    font-size: var(--step--1);
    color: var(--text-faint);
    font-variant-numeric: tabular-nums;
  }
  .title {
    margin: var(--space-2) 0 var(--space-1);
    font-size: var(--step-1);
  }
  .summary {
    margin: 0;
    color: var(--text-muted);
  }
</style>
