---
import type { Severity } from '@/lib/articles/article-types';
import { severityMeta } from '@/lib/severity/severity-meta';

interface Props {
  readonly severity: Severity;
}

const { severity } = Astro.props;
const meta = severityMeta(severity);
---

<span class="badge" style={`--c: var(${meta.cssVar})`} data-severity={severity}>
  {meta.label}
</span>

<style>
  .badge {
    display: inline-flex;
    align-items: center;
    gap: 0.4em;
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--c);
    border: 1px solid color-mix(in srgb, var(--c) 40%, transparent);
    background: color-mix(in srgb, var(--c) 10%, transparent);
    border-radius: 999px;
    padding: 0.2em 0.7em;
    white-space: nowrap;
  }
  .badge::before {
    content: '';
    width: 0.5em;
    height: 0.5em;
    border-radius: 50%;
    background: var(--c);
  }
</style>
