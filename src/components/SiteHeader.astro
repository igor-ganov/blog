---
import { type Locale, locales, localeLabels } from '@/lib/i18n/locales';
import { withLocale } from '@/lib/i18n/locale-url';
import { t } from '@/lib/i18n/ui';
import { withBase } from '@/lib/url/with-base';

interface Props {
  readonly locale: Locale;
}

const { locale } = Astro.props;
const ui = t(locale);
const nav = [
  { href: withLocale(locale, '/blog'), label: ui.nav.blog },
  { href: withLocale(locale, '/principles'), label: ui.nav.principles },
  { href: withLocale(locale, '/skills'), label: ui.nav.skills },
  { href: withLocale(locale, '/about'), label: ui.nav.about },
];
const path = Astro.url.pathname.replace(/\/$/, '');
const isActive = (href: string): boolean => path === href || path.startsWith(`${href}/`);

// The path within the current locale (everything after /<base>/<locale>), so the
// language switcher can point at the same page in another language.
const base = withBase('/').replace(/\/$/, '');
const afterBase = path.startsWith(base) ? path.slice(base.length) : path;
const restParts = afterBase.split('/').filter(Boolean).slice(1);
const restPath = restParts.length > 0 ? `/${restParts.join('/')}` : '/';

const langs = locales.map((loc) => ({
  href: withLocale(loc, restPath),
  loc,
  label: localeLabels[loc],
  current: loc === locale,
}));
---

<header class="site-header">
  <div class="wrap bar">
    <a class="brand" href={withLocale(locale, '/')}>
      <svg class="mark" viewBox="0 0 32 32" width="24" height="24" aria-hidden="true">
        <rect width="32" height="32" rx="6" fill="var(--bg-sunken)" />
        <rect x="7" y="8" width="3" height="16" rx="1.5" fill="var(--accent)" />
        <rect x="13" y="9" width="12" height="3" rx="1.5" fill="var(--text)" />
        <rect x="13" y="15" width="12" height="3" rx="1.5" fill="var(--text-muted)" />
        <rect x="13" y="21" width="8" height="3" rx="1.5" fill="var(--text-muted)" />
      </svg>
      <span class="word">{ui.brand}</span>
    </a>
    <nav class="primary desktop-only" aria-label={ui.nav.primary}>
      <ul>
        {
          nav.map((item) => (
            <li>
              <a href={item.href} aria-current={isActive(item.href) ? 'page' : undefined}>
                {item.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>
    <nav class="langs desktop-only" aria-label={ui.language}>
      <ul>
        {
          langs.map((item) => (
            <li>
              <a
                href={item.href}
                lang={item.loc}
                hreflang={item.loc}
                aria-current={item.current ? 'true' : undefined}
              >
                {item.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>
    <theme-toggle class="desktop-only" label={ui.theme.toggle}></theme-toggle>
  </div>

  {/* Mobile: the inline controls would overflow a phone width, so they move into a
      draggable, corner-snapping flying menu (igor-ganov/flying-menu). */}
  <flying-menu class="mobile-menu" corner="bottom-right" gap={12} storage-key="ep-menu-corner">
    <button slot="trigger" class="fab" type="button" aria-label={ui.nav.menu}>
      <svg viewBox="0 0 24 24" width="22" height="22" aria-hidden="true">
        <path
          d="M3 6h18M3 12h18M3 18h18"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"></path>
      </svg>
    </button>
    <div slot="menu" class="menu-panel">
      <nav aria-label={ui.nav.primary}>
        <ul>
          {
            nav.map((item) => (
              <li>
                <a href={item.href} aria-current={isActive(item.href) ? 'page' : undefined}>
                  {item.label}
                </a>
              </li>
            ))
          }
        </ul>
      </nav>
      <nav class="menu-langs" aria-label={ui.language}>
        <ul>
          {
            langs.map((item) => (
              <li>
                <a
                  href={item.href}
                  lang={item.loc}
                  hreflang={item.loc}
                  aria-current={item.current ? 'true' : undefined}
                >
                  {item.label}
                </a>
              </li>
            ))
          }
        </ul>
      </nav>
      <theme-toggle label={ui.theme.toggle}></theme-toggle>
    </div>
  </flying-menu>
</header>

<script>
  import '@/components/islands/theme-toggle';
  import '@igor-ganov/flying-menu';
</script>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 40;
    background: color-mix(in srgb, var(--bg) 88%, transparent);
    backdrop-filter: saturate(140%) blur(8px);
    border-bottom: 1px solid var(--border);
  }
  .bar {
    display: flex;
    align-items: center;
    gap: var(--space-5);
    min-height: 4rem;
  }
  .brand {
    display: inline-flex;
    align-items: center;
    gap: var(--space-3);
    font-weight: 600;
    color: var(--text);
    text-decoration: none;
  }
  .mark {
    flex: none;
    display: block;
    border-radius: 6px;
  }
  .word {
    font-family: var(--font-serif);
    letter-spacing: 0.01em;
  }
  nav.primary {
    margin-inline-start: auto;
  }
  ul {
    display: flex;
    gap: var(--space-5);
    list-style: none;
    margin: 0;
    padding: 0;
  }
  nav a {
    color: var(--text-muted);
    text-decoration: none;
    padding: var(--space-1) 0;
    border-bottom: 2px solid transparent;
  }
  nav a:hover {
    color: var(--text);
  }
  nav a[aria-current='page'] {
    color: var(--text);
    border-bottom-color: var(--accent);
  }
  .langs ul {
    gap: var(--space-3);
    font-size: var(--step--1);
  }
  .langs a[aria-current='true'] {
    color: var(--text);
    font-weight: 600;
  }

  /* The flying menu is mobile-only; hidden on wider screens where the inline bar fits. */
  .mobile-menu {
    display: none;
  }

  @media (max-width: 48rem) {
    .word {
      display: none;
    }
    .desktop-only {
      display: none;
    }
    .mobile-menu {
      display: contents;
    }
  }

  /* Floating trigger button (the FAB). */
  .fab {
    display: inline-grid;
    place-items: center;
    width: 3rem;
    height: 3rem;
    border-radius: 999px;
    border: 1px solid var(--border-strong);
    background: var(--bg-raised);
    color: var(--text);
    box-shadow: var(--shadow);
    cursor: pointer;
    touch-action: none;
  }
  .fab:focus-visible {
    outline: 3px solid var(--accent);
    outline-offset: 2px;
  }

  /* The menu panel shown when the flying menu is open. */
  .menu-panel {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    min-width: 12rem;
    padding: var(--space-5);
    background: var(--bg-raised);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    box-shadow: var(--shadow);
  }
  .menu-panel nav ul {
    flex-direction: column;
    gap: var(--space-3);
  }
  .menu-panel .menu-langs ul {
    flex-direction: row;
    flex-wrap: wrap;
    gap: var(--space-4);
    padding-top: var(--space-3);
    border-top: 1px solid var(--border);
    font-size: var(--step--1);
  }
  .menu-panel .menu-langs a[aria-current='true'] {
    color: var(--text);
    font-weight: 600;
  }
</style>
