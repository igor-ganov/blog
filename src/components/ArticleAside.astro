---
import type { Article, ArticleSource } from '@/lib/articles/article-types';
import { formatDate } from '@/lib/format/format-date';
import type { Locale } from '@/lib/i18n/locales';
import { t } from '@/lib/i18n/ui';

interface RelatedLink {
  readonly href: string;
  readonly title: string;
}

interface Props {
  readonly sources: readonly ArticleSource[];
  readonly related: readonly RelatedLink[];
  readonly tags: Article['tags'];
  readonly locale: Locale;
}

const { sources, related, tags, locale } = Astro.props;
const ui = t(locale);
---

<aside class="aside" aria-label={`${ui.aside.provenance} · ${ui.aside.related}`}>
  {
    sources.length > 0 && (
      <section>
        <h2 class="h">{ui.aside.provenance}</h2>
        <ul class="sources">
          {sources.map((source) => (
            <li>
              <span class="proj">{source.project}</span>
              <time datetime={source.date}>{formatDate(source.date)}</time>
              {source.note && <span class="note">{source.note}</span>}
            </li>
          ))}
        </ul>
      </section>
    )
  }
  {
    tags.length > 0 && (
      <section>
        <h2 class="h">{ui.aside.tags}</h2>
        <ul class="tags">
          {tags.map((tag) => (
            <li>{tag}</li>
          ))}
        </ul>
      </section>
    )
  }
  {
    related.length > 0 && (
      <section>
        <h2 class="h">{ui.aside.related}</h2>
        <ul class="related">
          {related.map((link) => (
            <li>
              <a href={link.href}>{link.title}</a>
            </li>
          ))}
        </ul>
      </section>
    )
  }
</aside>

<style>
  .aside {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
    font-size: var(--step--1);
  }
  .h {
    font-family: var(--font-sans);
    font-size: 0.74rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text-faint);
    margin: 0 0 var(--space-3);
  }
  ul {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .sources li {
    display: flex;
    flex-direction: column;
    padding: var(--space-2) 0;
    border-bottom: 1px solid var(--border);
  }
  .proj {
    font-weight: 600;
    color: var(--text);
  }
  .sources time {
    color: var(--text-faint);
    font-variant-numeric: tabular-nums;
  }
  .note {
    color: var(--text-muted);
    margin-top: var(--space-1);
  }
  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }
  .tags li {
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    padding: 0.1em 0.5em;
    color: var(--text-muted);
  }
  .related li {
    padding: var(--space-1) 0;
  }
</style>
