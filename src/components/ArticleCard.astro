---
import SeverityBadge from '@/components/SeverityBadge.astro';
import type { Article } from '@/lib/articles/article-types';
import { articleHaystack } from '@/lib/articles/article-haystack';
import { articleHref } from '@/lib/articles/article-href';
import { categoryBySlug } from '@/lib/categories/categories';
import { KB_FILTER } from '@/components/islands/kb-filter.locators';

interface Props {
  readonly article: Article;
  readonly showCategory?: boolean;
}

const { article, showCategory = false } = Astro.props;
const category = categoryBySlug(article.category);
const attrs = { [KB_FILTER.item]: '', [KB_FILTER.haystack]: articleHaystack(article) };
---

<article class="card" {...attrs}>
  <a class="hit" href={articleHref(article)} aria-label={article.title}></a>
  <div class="top">
    <SeverityBadge severity={article.severity} />
    {showCategory && category && <span class="cat">{category.title}</span>}
  </div>
  <h3 class="title">{article.title}</h3>
  <p class="summary">{article.summary}</p>
  {
    article.tags.length > 0 && (
      <ul class="tags">
        {article.tags.slice(0, 4).map((tag) => (
          <li>{tag}</li>
        ))}
      </ul>
    )
  }
</article>

<style>
  .card {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    background: var(--bg-raised);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: var(--space-4) var(--space-5);
    transition: border-color 0.15s ease, transform 0.15s ease, box-shadow 0.15s ease;
  }
  .card:hover {
    border-color: var(--border-strong);
    transform: translateY(-2px);
    box-shadow: var(--shadow);
  }
  .card:focus-within {
    outline: 3px solid var(--accent);
    outline-offset: 2px;
  }
  .hit {
    position: absolute;
    inset: 0;
    border-radius: inherit;
  }
  .hit:focus-visible {
    outline: none;
  }
  .top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-2);
  }
  .cat {
    font-size: var(--step--1);
    color: var(--text-faint);
  }
  .title {
    font-size: var(--step-1);
    margin: var(--space-1) 0 0;
  }
  .summary {
    margin: 0;
    color: var(--text-muted);
  }
  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    list-style: none;
    margin: var(--space-2) 0 0;
    padding: 0;
    position: relative;
  }
  .tags li {
    font-size: 0.72rem;
    color: var(--text-faint);
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    padding: 0.1em 0.5em;
  }
</style>
