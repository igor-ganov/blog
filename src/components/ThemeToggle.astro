---
import type { Locale } from '@/lib/i18n/locales';
import { t } from '@/lib/i18n/ui';
import { THEME_TOGGLE } from '@/components/islands/theme-toggle.locators';

interface Props {
  readonly locale: Locale;
  readonly class?: string;
}

const { locale, class: className } = Astro.props;
const ui = t(locale);

// Server-rendered so the button exists on first paint (no hydration reflow). The
// active icon is chosen by CSS from <html data-theme-pref>, so it is correct before
// the enhancer script runs — no glyph flash. The default SSR state is `system`.
---

<button
  type="button"
  class:list={['theme-toggle', className]}
  data-theme-toggle
  data-testid={THEME_TOGGLE.button}
  data-label={ui.theme.toggle}
  data-name-light={ui.theme.light}
  data-name-dark={ui.theme.dark}
  data-name-system={ui.theme.system}
  aria-label={`${ui.theme.toggle} (${ui.theme.system})`}
>
  <span class="ti ti-light" aria-hidden="true">
    <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round">
      <circle cx="12" cy="12" r="4.5"></circle>
      <path d="M12 2v2M12 20v2M2 12h2M20 12h2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M19.1 4.9l-1.4 1.4M6.3 17.7l-1.4 1.4"></path>
    </svg>
  </span>
  <span class="ti ti-dark" aria-hidden="true">
    <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
      <path d="M21 12.8A9 9 0 1 1 11.2 3 7 7 0 0 0 21 12.8z"></path>
    </svg>
  </span>
  <span class="ti ti-system" aria-hidden="true">
    <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
      <rect x="3" y="4" width="18" height="13" rx="2"></rect>
      <path d="M8 21h8M12 17v4"></path>
    </svg>
  </span>
</button>

<style>
  .theme-toggle {
    width: 2.4rem;
    height: 2.4rem;
    display: inline-grid;
    place-items: center;
    cursor: pointer;
    color: var(--text);
    background: var(--bg-raised);
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    -webkit-tap-highlight-color: transparent;
    transition: border-color 0.15s ease, background 0.15s ease;
  }
  .theme-toggle:hover {
    border-color: var(--border-strong);
    background: var(--bg-sunken);
  }
  .theme-toggle:active {
    background: var(--bg-sunken);
  }
  .theme-toggle:focus-visible {
    outline: 3px solid var(--accent);
    outline-offset: 2px;
  }
  /* All three icons share the same grid cell; only the active preference shows. */
  .ti {
    grid-area: 1 / 1;
    display: none;
    place-items: center;
  }
  :global(html[data-theme-pref='light']) .ti-light,
  :global(html[data-theme-pref='dark']) .ti-dark,
  :global(html[data-theme-pref='system']) .ti-system {
    display: inline-grid;
  }
  /* Before the inline head script sets a preference, fall back to the system icon. */
  :global(html:not([data-theme-pref])) .ti-system {
    display: inline-grid;
  }
</style>
