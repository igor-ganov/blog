---
import { ClientRouter } from 'astro:transitions';
import SiteFooter from '@/components/SiteFooter.astro';
import SiteHeader from '@/components/SiteHeader.astro';
import type { Locale } from '@/lib/i18n/locales';
import { t } from '@/lib/i18n/ui';
import { withBase } from '@/lib/url/with-base';
import '@/styles/global.css';

interface Props {
  readonly title: string;
  readonly description: string;
  readonly locale: Locale;
}

const { title, description, locale } = Astro.props;
const ui = t(locale);
const fullTitle = `${title} · ${ui.titleSuffix}`;
---

<!doctype html>
<html lang={locale} data-theme="light" data-theme-pref="system">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <meta name="color-scheme" content="light dark" />
    <link rel="icon" href={withBase('/favicon.svg')} type="image/svg+xml" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="article" />
    {/* SPA-like navigation: no white flash, no layout jump, instant prefetched loads. */}
    <ClientRouter />
    {/* Resolve the stored preference (light/dark/system) to a concrete theme before
        first paint, after every view-transition swap, and whenever the OS scheme
        changes while on `system`. `data-theme-pref` drives the toggle's active icon;
        `data-theme` drives the colours. */}
    <script is:inline>
      (function () {
        var root = document.documentElement;
        var darkQuery = window.matchMedia('(prefers-color-scheme: dark)');
        function known(value) {
          return value === 'light' || value === 'dark' || value === 'system';
        }
        function applyTheme() {
          try {
            var stored = localStorage.getItem('theme');
            var pref = known(stored) ? stored : 'system';
            var dark = pref === 'dark' || (pref === 'system' && darkQuery.matches);
            root.dataset.themePref = pref;
            root.dataset.theme = dark ? 'dark' : 'light';
          } catch (error) {
            root.dataset.themePref = 'system';
            root.dataset.theme = 'light';
          }
        }
        applyTheme();
        if (!window.__themeBound) {
          window.__themeBound = true;
          document.addEventListener('astro:after-swap', applyTheme);
          darkQuery.addEventListener('change', function () {
            if (root.dataset.themePref === 'system') applyTheme();
          });
        }
      })();
    </script>
  </head>
  <body>
    <a class="skip-link" href="#main">{ui.skipToContent}</a>
    <SiteHeader locale={locale} />
    <main id="main" class="wrap">
      <slot />
    </main>
    <SiteFooter locale={locale} />
    {/* Register the service worker that caches content-hashed assets long-term,
        working around GitHub Pages' fixed max-age=600 on every response. */}
    <script is:inline define:vars={{ swUrl: withBase('/sw.js') }}>
      if ('serviceWorker' in navigator) {
        window.addEventListener('load', function () {
          navigator.serviceWorker.register(swUrl).catch(function () {});
        });
      }
    </script>
  </body>
</html>
