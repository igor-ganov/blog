{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bun scripts/llm-smell-hook.ts",
            "statusMessage": "Checking article for LLM smells"
          }
        ]
      }
    ]
  }
}
